{
  "name": "Spring Boot (Java 25)",
  "dockerComposeFile": "docker-compose.yaml",
  "service": "app",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-boot-dev-pack"
      ]
    }
  },
  "postCreateCommand": "sudo chown -R ubuntu:ubuntu /home/ubuntu/.gradle",
  "remoteUser": "ubuntu"
}